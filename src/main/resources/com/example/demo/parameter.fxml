<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="300.0" prefWidth="400.0" spacing="15.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demo.ParameterController">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Label text="Login Setup">
        <font>
            <Font name="System Bold" size="24.0"/>
        </font>
        <VBox.margin>
            <Insets bottom="20.0"/>
        </VBox.margin>
    </Label>

    <Label text="Max failed attempts (n):"/>
    <TextField fx:id="maxAttemptsField" promptText="e.g. 3"/>

    <Label text="Block duration in seconds (t):"/>
    <TextField fx:id="blockDurationField" promptText="e.g. 10"/>

    <Label fx:id="errorLabel" textFill="RED"/>

    <Button mnemonicParsing="false" onAction="#onStartButtonClick" text="Start">
        <VBox.margin>
            <Insets top="10.0"/>
        </VBox.margin>
    </Button>

</VBox>